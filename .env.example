# Clerk Authentication
VITE_CLERK_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Admin user ID (for admin role access)
VITE_ADMIN_USER_ID=your-admin-user-id

# Gemini AI (optional, for AI search in BrowseShipments)
VITE_GEMINI_API_KEY=your-gemini-api-key

# IMPORTANT: For Vercel deployment, add these exact variables (same names)
# to Vercel Dashboard -> Project Settings -> Environment Variables.
# Do NOT rely on a local .env file pushed to the repo — Vercel ignores it.
